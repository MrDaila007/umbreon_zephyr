/*
 * Devicetree overlay for Umbreon roborace car — Raspberry Pi Pico 2 (RP2350A)
 *
 * Pin assignment:
 *   I2C0  GP0/GP1  400kHz — MPU-6050 (0x68)
 *   I2C1  GP2/GP3  100kHz — 6× VL53L0X (0x30–0x35)
 *   UART0 GP16/GP17 115200 — Debug console
 *   UART1 GP4/GP5   115200 — WiFi bridge (ESP8266)
 *   PWM   GP10 (slice 5A) — Steering servo
 *   PWM   GP11 (slice 5B) — Motor ESC
 *   GPIO  GP13 — Tachometer interrupt (RISING)
 *   ADC   GP26 (ch0) — Battery voltage
 *   GPIO  GP6,7,8,9,14,15 — VL53L0X XSHUT pins
 */

#include <zephyr/dt-bindings/pwm/pwm.h>
#include <zephyr/dt-bindings/i2c/i2c.h>

/ {
	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,flash-controller = &qmi;
	};

	pwmleds {
		compatible = "pwm-leds";
		servo: servo_pwm {
			pwms = <&pwm 10 20000000 PWM_POLARITY_NORMAL>;
		};
		esc: esc_pwm {
			pwms = <&pwm 11 20000000 PWM_POLARITY_NORMAL>;
		};
	};

	tachometer {
		compatible = "gpio-keys";
		tach_pin: tach {
			gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;
			label = "Tachometer";
		};
	};

	/* ─── Bit-bang I2C for SSD1306 OLED (GP18=SDA, GP20=SCL) ──────────── */
	i2c_oled: i2c-oled {
		compatible = "gpio-i2c";
		sda-gpios = <&gpio0 18 (GPIO_OPEN_DRAIN | GPIO_PULL_UP)>;
		scl-gpios = <&gpio0 20 (GPIO_OPEN_DRAIN | GPIO_PULL_UP)>;
		clock-frequency = <100000>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";

		ssd1306: ssd1306@3c {
			compatible = "solomon,ssd1306fb";
			reg = <0x3c>;
			width = <128>;
			height = <64>;
			segment-offset = <0>;
			page-offset = <0>;
			display-offset = <0>;
			multiplex-ratio = <63>;
			segment-remap;
			com-invdir;
			prechargep = <0x22>;
			ready-time-ms = <200>;
		};
	};

	encoder {
		compatible = "gpio-keys";
		enc_a: enc_clk {
			gpios = <&gpio0 22 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Encoder CLK";
		};
		enc_b: enc_dt {
			gpios = <&gpio0 12 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Encoder DT";
		};
		enc_sw: enc_btn {
			gpios = <&gpio0 19 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Encoder Button";
		};
	};
};

/* ─── Pinctrl overrides ──────────────────────────────────────────────────── */

/* Override I2C0 pins: GP0 (SDA), GP1 (SCL) — for MPU-6050 */
&i2c0_default {
	group1 {
		pinmux = <I2C0_SDA_P0>, <I2C0_SCL_P1>;
		input-enable;
		input-schmitt-enable;
	};
};

/* Override I2C1 pins: GP2 (SDA), GP3 (SCL) — for VL53L0X */
&i2c1_default {
	group1 {
		pinmux = <I2C1_SDA_P2>, <I2C1_SCL_P3>;
		input-enable;
		input-schmitt-enable;
	};
};

/* UART0 pins: GP16 (TX), GP17 (RX) — debug console */
&uart0_default {
	group1 {
		pinmux = <UART0_TX_P16>;
	};
	group2 {
		pinmux = <UART0_RX_P17>;
		input-enable;
	};
};

/* UART1 pins: GP4 (TX), GP5 (RX) — WiFi bridge (ESP8266) */
&pinctrl {
	uart1_default: uart1_default {
		group1 {
			pinmux = <UART1_TX_P4>;
		};
		group2 {
			pinmux = <UART1_RX_P5>;
			input-enable;
		};
	};
};

/* New pinctrl group for PWM slice 5 (servo + ESC) */
&pinctrl {
	pwm_ch5ab_default: pwm_ch5ab_default {
		group1 {
			pinmux = <PWM_5A_P10>, <PWM_5B_P11>;
		};
	};
};

/* ─── I2C0: MPU-6050 gyroscope ───────────────────────────────────────────── */
&i2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	mpu6050: mpu6050@68 {
		compatible = "invensense,mpu6050";
		reg = <0x68>;
		status = "okay";
	};

	/* SSD1306 moved to dedicated i2c-gpio bus (i2c_oled) */
};

/* ─── I2C1: 6× VL53L0X ToF sensors ──────────────────────────────────────── */
&i2c1 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_STANDARD>;

	vl53l0x_0: vl53l0x@30 {
		compatible = "st,vl53l0x";
		reg = <0x30>;
		xshut-gpios = <&gpio0 6 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
	vl53l0x_1: vl53l0x@31 {
		compatible = "st,vl53l0x";
		reg = <0x31>;
		xshut-gpios = <&gpio0 7 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
	vl53l0x_2: vl53l0x@32 {
		compatible = "st,vl53l0x";
		reg = <0x32>;
		xshut-gpios = <&gpio0 8 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
	vl53l0x_3: vl53l0x@33 {
		compatible = "st,vl53l0x";
		reg = <0x33>;
		xshut-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
	vl53l0x_4: vl53l0x@34 {
		compatible = "st,vl53l0x";
		reg = <0x34>;
		xshut-gpios = <&gpio0 14 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
	vl53l0x_5: vl53l0x@35 {
		compatible = "st,vl53l0x";
		reg = <0x35>;
		xshut-gpios = <&gpio0 15 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
};

/* ─── UART0: Debug console (GP16 TX, GP17 RX) ────────────────────────────── */
&uart0 {
	status = "okay";
	current-speed = <115200>;
};

/* ─── UART1: WiFi bridge (GP4 TX, GP5 RX) ────────────────────────────────── */
&uart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-names = "default";
};

/* ─── PWM: Servo (GP10) + ESC (GP11) ─────────────────────────────────────── */
&pwm {
	status = "okay";
	pinctrl-0 = <&pwm_ch5ab_default>;
	pinctrl-names = "default";
};

/* ─── Flash partitions: add NVS storage ──────────────────────────────────── */
&flash0 {
	partitions {
		/* Override code_partition to shrink it, making room for NVS */
		/delete-node/ partition@100;

		code_partition: partition@100 {
			label = "code-partition";
			reg = <0x100 (DT_SIZE_M(4) - 0x100 - 0x10000)>;
			read-only;
		};

		storage_partition: partition@3f0000 {
			label = "storage";
			reg = <0x003F0000 0x00010000>;
		};
	};
};

/* ─── Enable watchdog (disabled in SoC DTS) ──────────────────────────────── */
&wdt0 {
	status = "okay";
};
